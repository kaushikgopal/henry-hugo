#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 <content-path> [--force] [--avatar <path>] [--desc]"
  echo "  content-path: path to a .md file or page bundle directory"
  echo "  --force: regenerate even if output is up-to-date"
  echo "  --avatar: override avatar image (Hugo-style path, e.g. /images/logo.png)"
  echo "  --desc: show description text below title"
  exit 1
}

[[ $# -lt 1 ]] && usage

INPUT="$1"
shift
FORCE=false
AVATAR=""
SHOW_DESC=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE=true; shift ;;
    --avatar) AVATAR="$2"; shift 2 ;;
    --desc) SHOW_DESC=true; shift ;;
    *) echo "Unknown option: $1" >&2; usage ;;
  esac
done

PORT=13990
SESSION="og-$$"

# detect main config file (hugo supports yaml, toml, json)
if [[ -f "hugo.yaml" ]]; then
  main_config="hugo.yaml"
elif [[ -f "hugo.toml" ]]; then
  main_config="hugo.toml"
elif [[ -f "hugo.json" ]]; then
  main_config="hugo.json"
else
  echo "Error: no hugo config file found (hugo.yaml/toml/json)" >&2
  exit 1
fi

# extract baseURL from main config (hugo server overrides it otherwise)
if [[ "$main_config" == *.yaml ]] || [[ "$main_config" == *.yml ]]; then
  base_url=$(grep -m1 '^baseURL:' "$main_config" | sed 's/^baseURL: *//' | tr -d "\"'" || true)
elif [[ "$main_config" == *.toml ]]; then
  base_url=$(grep -m1 '^baseURL' "$main_config" | sed 's/^baseURL *= *//' | tr -d "\"'" || true)
fi
base_url="${base_url:-http://localhost:1313}"

# resolve post file and detect page bundles
# accepts: directory, directory/index.md, or standalone .md
is_bundle=false
if [[ -d "$INPUT" ]]; then
  post_file="${INPUT%/}/index.md"
  bundle_dir="${INPUT%/}"
  is_bundle=true
elif [[ -f "$INPUT" ]]; then
  post_file="$INPUT"
  if [[ "$(basename "$INPUT")" == "index.md" ]]; then
    bundle_dir="$(dirname "$INPUT")"
    is_bundle=true
  fi
else
  echo "Error: '$INPUT' is not a file or directory" >&2
  exit 1
fi

[[ ! -f "$post_file" ]] && echo "Error: '$post_file' not found" >&2 && exit 1

# resolve metadata via hugo list all
csv_line=$(hugo list all 2>/dev/null | grep "^${post_file}," || true)
if [[ -z "$csv_line" ]]; then
  echo "Error: '$post_file' not found in 'hugo list all' output" >&2
  exit 1
fi

# strip leading/trailing slashes from slug (e.g. /304/ → 304)
slug=$(echo "$csv_line" | cut -d',' -f2 | sed 's|^/||;s|/$||')
date_raw=$(echo "$csv_line" | cut -d',' -f4)
permalink=$(echo "$csv_line" | cut -d',' -f8)
section=$(echo "$csv_line" | cut -d',' -f10)
year=$(echo "$date_raw" | cut -c1-4)

# relative permalink path
rel_permalink=$(echo "$permalink" | sed 's|https://[^/]*/|/|')

# page bundles: output into the bundle directory (becomes a page resource)
# standalone posts: output to static/images/og/
if [[ "$is_bundle" == "true" ]]; then
  out="${bundle_dir}/${slug}.webp"
else
  out="static/images/og/${slug}.webp"
fi

# skip if up-to-date (unless --force)
if [[ "$FORCE" != "true" ]] && [[ -f "$out" ]] \
  && [[ "$out" -nt "$post_file" ]] \
  && [[ "$out" -nt "themes/henry/layouts/_default/single.og.htm" ]] \
  && [[ "$out" -nt "hugo.banner.yaml" ]] \
  && [[ "$out" -nt "$0" ]]; then
  echo "Up-to-date: $out"
  exit 0
fi

echo "Generating banner for: $slug ($section, $year)"
echo "  Output: $out"

# ensure output directory exists
mkdir -p "$(dirname "$out")"

tmp_png=$(mktemp /tmp/og-banner-XXXXXX.png)
override_config=""
trap 'rm -f "$tmp_png" "$override_config"; kill $(lsof -ti:'"$PORT"') 2>/dev/null || true; agent-browser --session "$SESSION" close 2>/dev/null || true' EXIT

# build config chain (with optional overrides via temp config)
config_chain="${main_config},hugo.banner.yaml"
override_config=""
if [[ -n "$AVATAR" ]] || [[ "$SHOW_DESC" == "true" ]]; then
  override_config=$(mktemp /tmp/og-override-XXXXXX.yaml)
  echo "params:" > "$override_config"
  [[ -n "$AVATAR" ]] && echo "  avatar: \"$AVATAR\"" >> "$override_config"
  [[ "$SHOW_DESC" == "true" ]] && echo "  og_show_desc: true" >> "$override_config"
  config_chain="${config_chain},${override_config}"
fi

# start hugo server in background
hugo server \
  --config "$config_chain" \
  --baseURL "$base_url" \
  --bind 127.0.0.1 \
  --port "$PORT" \
  --disableFastRender \
  --renderToMemory \
  --logLevel error &

# wait for server to be ready
echo "  Waiting for Hugo server on port $PORT..."
for i in $(seq 1 30); do
  if curl -s -o /dev/null "http://127.0.0.1:${PORT}/" 2>/dev/null; then
    break
  fi
  sleep 0.5
done

# verify the og.html page exists
url="http://127.0.0.1:${PORT}${rel_permalink}og.html"
status=$(curl -s -o /dev/null -w "%{http_code}" "$url")
if [[ "$status" != "200" ]]; then
  echo "Error: $url returned HTTP $status" >&2
  exit 1
fi

# screenshot with agent-browser
echo "  Screenshotting: $url"
agent-browser --session "$SESSION" open "$url"
agent-browser --session "$SESSION" set viewport 1200 630
agent-browser --session "$SESSION" wait --fn "window.__OG_READY === true"
agent-browser --session "$SESSION" screenshot "$tmp_png"
agent-browser --session "$SESSION" close

# convert to webp
echo "  Converting to WebP..."
cwebp -q 82 -m 6 -mt -sharp_yuv -metadata none "$tmp_png" -o "$out" 2>/dev/null

echo "Done: $out"
